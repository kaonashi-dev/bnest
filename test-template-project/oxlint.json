{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "no-unused-vars": "off",
    "typescript/no-explicit-any": "off",
    "typescript/ban-types": "off",
    "no-prototype-builtins": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/"]
}
