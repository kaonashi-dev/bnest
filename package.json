{
  "name": "@kaonashi-dev/bnest",
  "version": "0.1.2",
  "description": "Framework for Bun, powered by Elysia.js",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "bin": {
    "bnest": "src/cli/index.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test tests/*.test.ts src/queue/queue.test.ts",
    "test:watch": "bun test --watch tests/*.test.ts src/queue/queue.test.ts",
    "test:nestjs": "bun test tests/nestjs/",
    "check": "bun run lint && bun run format:check",
    "check:fix": "bun run lint:fix && bun run format",
    "build": "bun build src/index.ts --target=bun --outfile=dist/bnest.bun --minify",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "elysia": "^1.4.28",
    "reflect-metadata": "^0.2.2"
  }
}
